# Copiar a .env.local (desarrollo) o definir en el panel del host (Vercel, etc.).
# Sin barra final en la URL.

# Opcional pero recomendado en producción: genera sitemap.xml y robots.txt con Sitemap:
VITE_SITE_URL=https://tu-dominio.es

# Obligatorias (la app falla al cargar si faltan)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Formulario de contacto (EmailJS)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
